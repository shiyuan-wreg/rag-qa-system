# 复制此文件为 .env，然后填入你的真实 API Key
# 这个文件可以上传到 GitHub（不含真实密钥）
LLM_PROVIDER=qwen
LLM_MODEL=qwen-turbo
DASHSCOPE_API_KEY=your-dashscope-api-key

# DashScope 接入点。默认走大陆站(dashscope.aliyuncs.com)。
# 海外服务器(如本项目的韩国首尔节点)连不到大陆站,必须改用国际站,
# 且 DASHSCOPE_API_KEY 也要换成「国际版控制台」申请的 key(大陆 key 在国际站会 401)。
# 大陆站: 留空或不设此行即可
# 国际站: 取消下一行注释
# DASHSCOPE_HTTP_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Nexus 服务内部调用地址（Docker Compose 网络内使用服务名）
# RAG_URL=http://rag:8001
# FC_URL=http://fc:8002

# DocHub
DOCHUB_PASSWORD=your-secret-password
DOCHUB_ALLOW_PATH_CONVERT=false
DOCHUB_SECRET_KEY=your-secret-key-for-session
