# 复制此文件为 .env，然后填入你的真实 API Key
# 这个文件可以上传到 GitHub（不含真实密钥）

# ===== 聊天 LLM 出口 =====
# 默认通义千问(大陆),海外服务器连不到大陆 dashscope,改用 DeepSeek(OpenAI 兼容,海外可达)。
#
# 通义千问(大陆):
#   LLM_PROVIDER=qwen
#   LLM_MODEL=qwen-turbo
#   LLM_API_KEY=your-dashscope-api-key
#
# DeepSeek(推荐,海外服务器用):
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-deepseek-api-key

# ===== RAG 向量检索 embedding(Jina 托管,海外可达,免费额度) =====
# 去 https://jina.ai/embeddings 邮箱注册领取 key
JINA_API_KEY=your-jina-api-key

# Nexus 服务内部调用地址（Docker Compose 网络内使用服务名）
# RAG_URL=http://rag:8001
# FC_URL=http://fc:8002

# DocHub
DOCHUB_PASSWORD=your-secret-password
DOCHUB_ALLOW_PATH_CONVERT=false
DOCHUB_SECRET_KEY=your-secret-key-for-session
