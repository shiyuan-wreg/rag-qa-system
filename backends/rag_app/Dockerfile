FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY core/ ./core/
COPY rag/ ./rag/
COPY eval/ ./eval/
COPY docs/ ./docs/
COPY backends/rag_app/ ./backends/rag_app/
CMD ["uvicorn", "backends.rag_app.main:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1"]
