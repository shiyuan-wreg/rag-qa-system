# 敏感配置文件（包含真实 API Key）
.env

# 向量数据库（会自动生成，不需要上传）
chroma_db/

# Claude Code worktrees
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 前端依赖与构建产物(各 frontends/* 另有自己的 .gitignore,此处为根级安全网)
**/node_modules/
**/dist/

# DocHub output directories
backends/md_converter_app/uploads/
backends/md_converter_app/output/

# Generated HTML and temporary docx
# (这些文件由 DocHub 或本地脚本从 Markdown 生成,源文件已跟踪)
docs/*.html
docs/**/*.html
!docs/api-integration-for-harmonyos.md
!docs/index.md
docs/learning/*.docx

# SDD / superpowers working directory (progress ledgers live in .git/sdd or docs/superpowers)
.superpowers/

# Prompt exports (optional, keep if you want them tracked)
# docs/prompts/
